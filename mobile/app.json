{
  "expo": {
    "name": "Nexos Finanças",
    "slug": "mobile",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./public/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "gestorfinanceiro",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.gestorfinanceiro.mobile"
    },
    "android": {
      "versionCode": 4,
      "package": "com.gestorfinanceiro.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./public/icon-foreground.png",
        "backgroundColor": "#180024"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Permita que o Nexos Finanças use o Face ID para proteger seus dados financeiros."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 180,
          "resizeMode": "contain",
          "backgroundColor": "#f0f2f8",
          "dark": {
            "image": "./assets/splash-icon.png",
            "backgroundColor": "#0b0d14"
          }
        }
      ]
    ],
    "extra": {
      "apiBaseUrl": "https://financas.nexostech.com.br/api"
    }
  }
}
