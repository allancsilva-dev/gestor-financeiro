POSTGRES_DB=gestor_financeiro
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-owner-password

JWT_SECRET=change-long-random-secret-at-least-32-bytes

API_PORT=8080
CORS_ALLOWED_ORIGINS=https://financas.nexostech.com.br

COOKIE_SECURE=true
APP_DOCS_PUBLIC=false

# Microsoft 365 / Exchange Online (SMTP AUTH + STARTTLS)
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USERNAME=contato@nexostech.com.br
SMTP_PASSWORD=change-mailbox-password
MAIL_FROM=contato@nexostech.com.br

# TLS / Let's Encrypt (aponte o DNS A de DOMAIN para o IP da VPS antes de emitir)
DOMAIN=financas.nexostech.com.br
LETSENCRYPT_EMAIL=admin@example.com

BACKUP_RETENTION_DAYS=7
