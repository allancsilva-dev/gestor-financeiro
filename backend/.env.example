# ==========================================
# Gestor Financeiro — Variaveis de Ambiente
# ==========================================
# Copie para .env e preencha com valores reais.
# NUNCA comite .env com secrets reais.

# ---------- Banco de Dados ----------
DATABASE_URL=jdbc:postgresql://localhost:5432/gestor_financeiro
DB_USERNAME=postgres
DB_PASSWORD=change-me

# ---------- JWT ----------
JWT_SECRET=change-me-minimo-32-caracteres-aleatorios

# ---------- SMTP opcional ----------
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
MAIL_FROM=

# ---------- Servidor ----------
PORT=8080

# ---------- CORS ----------
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ---------- Profile ----------
SPRING_PROFILES_ACTIVE=dev
