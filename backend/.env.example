# ==========================================
# CONFIGURAÇÕES DE AMBIENTE
# ==========================================
# Copie este arquivo para .env e preencha os valores

# Banco de Dados
DATABASE_URL=jdbc:postgresql://localhost:5432/gestor_financeiro
DB_USERNAME=postgres
DB_PASSWORD=sua_senha_aqui

# JWT Secret (MÍNIMO 256 bits / 32 caracteres)
# Gere com: openssl rand -base64 32
JWT_SECRET=seu_jwt_secret_base64_32_bytes_aqui

# Ambiente
SPRING_PROFILES_ACTIVE=dev
PORT=8081

# Frontend URL (para CORS)
FRONTEND_URL=http://localhost:5173

# Origens permitidas no CORS (separadas por virgula)
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Cookies seguros (true em producao)
COOKIE_SECURE=false
