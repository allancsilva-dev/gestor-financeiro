# ==========================================
# CONFIGURAÇÕES DE AMBIENTE
# ==========================================
# Copie este arquivo para .env e preencha os valores

# Banco de Dados principal (VPS Hostinger)
DATABASE_URL=jdbc:postgresql://187.77.61.191:5433/dbnexos-gestor-financeiro
DB_USERNAME=admin_nexos
DB_PASSWORD=sua_senha_aqui

# JWT Secret (MÍNIMO 256 bits / 32 caracteres)
# Gere com: openssl rand -base64 32
JWT_SECRET=seu_jwt_secret_base64_32_bytes_aqui

# Ambiente
SPRING_PROFILES_ACTIVE=vps
PORT=8081

# Frontend URL (para CORS)
FRONTEND_URL=http://localhost:5173

# Origens permitidas no CORS (separadas por virgula)
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Cookies seguros (true em producao)
COOKIE_SECURE=false
