    <diagram id="auth-flow" name="02 Auth flow">
        <mxGraphModel dx="876" dy="670" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="1000" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <mxCell id="auth-title" value="Fluxo de autenticacao e sessao" style="text;html=1;strokeColor=none;fillColor=none;fontSize=24;fontStyle=1;align=center;verticalAlign=middle;" parent="1" vertex="1">
                    <mxGeometry x="360" y="20" width="680" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="a-user" value="Usuario&lt;br&gt;email + senha" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F4FF;strokeColor=#4F8FCF;fontSize=13;align=center;verticalAlign=middle;" parent="1" vertex="1">
                    <mxGeometry x="70" y="130" width="140" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="a-login" value="POST /api/auth/login" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#4F8FCF;fontSize=13;align=center;verticalAlign=middle;" parent="1" vertex="1">
                    <mxGeometry x="260" y="130" width="170" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="a-rate" value="LoginRateLimitFilter&lt;br&gt;5/min/IP&lt;br&gt;forgot-password: 3/min/IP" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=12;align=center;verticalAlign=middle;" parent="1" vertex="1">
                    <mxGeometry x="480" y="120" width="170" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="a-controller" value="AuthController.login()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#82B366;fontSize=13;align=center;verticalAlign=middle;" parent="1" vertex="1">
                    <mxGeometry x="700" y="130" width="170" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="a-authmgr" value="AuthenticationManager&lt;br&gt;CustomUserDetailsService&lt;br&gt;BCryptPasswordEncoder" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F0F7EA;strokeColor=#82B366;fontSize=12;align=center;verticalAlign=middle;" parent="1" vertex="1">
                    <mxGeometry x="920" y="120" width="190" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="a-decision" value="Credenciais OK?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=12;align=center;verticalAlign=middle;" parent="1" vertex="1">
                    <mxGeometry x="1160" y="125" width="120" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="a-error" value="401&lt;br&gt;Mensagem generica&lt;br&gt;Email ou senha incorretos" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=12;align=center;verticalAlign=middle;" parent="1" vertex="1">
                    <mxGeometry x="1125" y="250" width="190" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="a-jwt" value="JwtUtil.generateToken()&lt;br&gt;HS256&lt;br&gt;expiracao: 15 min&lt;br&gt;subject: email" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#82B366;fontSize=12;align=center;verticalAlign=middle;" parent="1" vertex="1">
                    <mxGeometry x="80" y="330" width="180" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="a-refresh" value="RefreshTokenService.criarRefreshToken()&lt;br&gt;UUID v4&lt;br&gt;validade: 7 dias&lt;br&gt;revogado=false" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#82B366;fontSize=12;align=center;verticalAlign=middle;" parent="1" vertex="1">
                    <mxGeometry x="320" y="330" width="210" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="a-db" value="refresh_tokens&lt;br&gt;usuario_id&lt;br&gt;token unique&lt;br&gt;data_expiracao&lt;br&gt;data_criacao&lt;br&gt;revogado" style="shape=cylinder3d;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#F5F0FF;strokeColor=#9673A6;fontSize=12;align=center;verticalAlign=middle;" parent="1" vertex="1">
                    <mxGeometry x="590" y="325" width="150" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="a-response" value="HTTP 200&lt;br&gt;Body: { accessToken, usuario }&lt;br&gt;Set-Cookie: refreshToken&lt;br&gt;HttpOnly, SameSite=Lax&lt;br&gt;Path=/api/auth&lt;br&gt;Secure em prod" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F4FF;strokeColor=#4F8FCF;fontSize=12;align=center;verticalAlign=middle;" parent="1" vertex="1">
                    <mxGeometry x="800" y="315" width="240" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="a-web-store" value="Web AuthContext&lt;br&gt;accessToken em memoria&lt;br&gt;refreshToken no cookie&lt;br&gt;getMe em /api/v1/usuarios/me" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#4F8FCF;fontSize=12;align=center;verticalAlign=middle;" parent="1" vertex="1">
                    <mxGeometry x="1100" y="350" width="210" height="100" as="geometry"/>
                </mxCell>
