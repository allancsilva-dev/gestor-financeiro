    <diagram id="ownership-flow" name="03 Ownership">
        <mxGraphModel dx="876" dy="670" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="1000" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <mxCell id="own-title" value="Fluxo single-tenant / ownership" style="text;html=1;strokeColor=none;fillColor=none;fontSize=24;fontStyle=1;align=center;verticalAlign=middle;" parent="1" vertex="1">
                    <mxGeometry x="360" y="20" width="680" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="o-req" value="Request protegido&lt;br&gt;Ex.: GET /api/v1/transacoes/42&lt;br&gt;Authorization: Bearer eyJ..." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F4FF;strokeColor=#4F8FCF;fontSize=12;align=center;verticalAlign=middle;" parent="1" vertex="1">
                    <mxGeometry x="70" y="120" width="210" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="o-filter" value="JwtAuthenticationFilter&lt;br&gt;valida JWT&lt;br&gt;extrai subject=email" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=12;align=center;verticalAlign=middle;" parent="1" vertex="1">
                    <mxGeometry x="340" y="120" width="180" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="o-context" value="SecurityContextHolder&lt;br&gt;Authentication.name = email" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F0F7EA;strokeColor=#82B366;fontSize=12;align=center;verticalAlign=middle;" parent="1" vertex="1">
                    <mxGeometry x="580" y="130" width="190" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="o-authsvc" value="AuthenticatedUserService&lt;br&gt;getAuthenticatedUserId()&lt;br&gt;busca Usuario por email" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#82B366;fontSize=12;align=center;verticalAlign=middle;" parent="1" vertex="1">
                    <mxGeometry x="830" y="115" width="210" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="o-userdb" value="usuarios&lt;br&gt;id, nome, email, senha" style="shape=cylinder3d;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#F5F0FF;strokeColor=#9673A6;fontSize=12;align=center;verticalAlign=middle;" parent="1" vertex="1">
                    <mxGeometry x="1100" y="120" width="150" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="o-controller" value="Controller do recurso&lt;br&gt;recebe id/path/query/body&lt;br&gt;nao aceita usuario_id no body" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#82B366;fontSize=12;align=center;verticalAlign=middle;" parent="1" vertex="1">
                    <mxGeometry x="100" y="330" width="220" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="o-service" value="Service&lt;br&gt;usa userId autenticado&lt;br&gt;buscarPorIdDoUsuario(id,userId)&lt;br&gt;regras de negocio" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#82B366;fontSize=12;align=center;verticalAlign=middle;" parent="1" vertex="1">
                    <mxGeometry x="400" y="315" width="240" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="o-repo" value="Repository&lt;br&gt;findByUsuarioId(...)&lt;br&gt;findById + checagem manual&lt;br&gt;queries por usuarioId" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#82B366;fontSize=12;align=center;verticalAlign=middle;" parent="1" vertex="1">
                    <mxGeometry x="730" y="315" width="220" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="o-resource" value="Recurso no banco&lt;br&gt;transacoes, categorias, contas,&lt;br&gt;carteiras, contas_fixas, metas&lt;br&gt;todas com usuario_id&lt;br&gt;parcelas herdam ownership via transacao" style="shape=cylinder3d;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#F5F0FF;strokeColor=#9673A6;fontSize=12;align=center;verticalAlign=middle;" parent="1" vertex="1">
                    <mxGeometry x="1030" y="300" width="230" height="140" as="geometry"/>
                </mxCell>
                <mxCell id="o-decision" value="resource.usuario.id == userId?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=12;align=center;verticalAlign=middle;" parent="1" vertex="1">
                    <mxGeometry x="500" y="550" width="170" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="o-ok" value="OK&lt;br&gt;retorna DTO&lt;br&gt;200/201/204" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=12;align=center;verticalAlign=middle;" parent="1" vertex="1">
                    <mxGeometry x="780" y="565" width="160" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="o-forbid" value="Bloqueia acesso&lt;br&gt;UnauthorizedAccessException&lt;br&gt;GlobalExceptionHandler&lt;br&gt;403" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=12;align=center;verticalAlign=middle;" parent="1" vertex="1">
                    <mxGeometry x="230" y="555" width="190" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="o-list" value="Listagens&lt;br&gt;/minhas e dashboard&lt;br&gt;sempre filtram por userId&lt;br&gt;ex.: findByUsuarioId(userId, pageable)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F4FF;strokeColor=#4F8FCF;fontSize=12;align=left;verticalAlign=top;spacing=10;" parent="1" vertex="1">
                    <mxGeometry x="100" y="740" width="290" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="o-risk" value="Ponto de atencao documentado&lt;br&gt;Ownership e manual por service; novos endpoints podem esquecer checagem.&lt;br&gt;Auditoria tambem marcou risco em TransacaoService: categoriaId/contaId na criacao precisam validacao completa de ownership." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=12;align=left;verticalAlign=top;spacing=10;" parent="1" vertex="1">
