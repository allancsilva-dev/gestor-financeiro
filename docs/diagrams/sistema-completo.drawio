                <mxCell id="spring" value="Spring Boot 3.5.7 / Java 17&lt;br&gt;Porta dev: 8081 | prod: ${PORT:8080}&lt;br&gt;API publica: /api/auth/*&lt;br&gt;API versionada: /api/v1/*&lt;br&gt;Swagger: /swagger-ui.html&lt;br&gt;Actuator: /actuator/health, /actuator/info" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#5A9E3F;fontSize=13;align=left;verticalAlign=top;spacing=10;" parent="1" vertex="1">
