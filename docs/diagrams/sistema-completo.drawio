                    <mxGeometry x="590" y="565" width="170" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="a-refreshcall" value="Web interceptor&lt;br&gt;fila requisicoes concorrentes&lt;br&gt;POST /api/auth/refresh-token" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#4F8FCF;fontSize=12;align=center;verticalAlign=middle;" parent="1" vertex="1">
                    <mxGeometry x="820" y="550" width="210" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="a-rotate" value="RefreshTokenService&lt;br&gt;verifica expiracao/revogado&lt;br&gt;rotaciona token&lt;br&gt;reuse detectado =&gt; revoga todos tokens do usuario" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F0F7EA;strokeColor=#82B366;fontSize=12;align=center;verticalAlign=middle;" parent="1" vertex="1">
