                    <mxGeometry x="90" y="560" width="200" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="a-jwtfilter" value="JwtAuthenticationFilter&lt;br&gt;valida token&lt;br&gt;seta SecurityContext" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F0F7EA;strokeColor=#82B366;fontSize=12;align=center;verticalAlign=middle;" parent="1" vertex="1">
