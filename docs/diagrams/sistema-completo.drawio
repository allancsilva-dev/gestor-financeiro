                <mxCell id="web" value="Frontend web&lt;br&gt;&lt;b&gt;React 19 + TypeScript + Vite&lt;/b&gt;&lt;br&gt;Tailwind CSS, React Router, Recharts&lt;br&gt;&lt;br&gt;Rotas publicas: /login, /register, forgot/reset&lt;br&gt;Rotas privadas: dashboard, categorias, contas, transacoes, metas, carteira, contas-fixas&lt;br&gt;&lt;br&gt;Axios: base /api; interceptor adiciona /v1 em endpoints nao-auth&lt;br&gt;Auth: accessToken em memoria + refreshToken em cookie HttpOnly" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#4F8FCF;fontSize=12;align=left;verticalAlign=top;spacing=10;" parent="1" vertex="1">
                    <mxGeometry x="90" y="140" width="210" height="220" as="geometry"/>
                </mxCell>
                <mxCell id="mobile" value="Mobile&lt;br&gt;&lt;b&gt;Expo SDK 54 + React Native 0.81&lt;/b&gt;&lt;br&gt;Expo Router, TanStack Query, NativeWind&lt;br&gt;&lt;br&gt;Rotas: (auth)/login, (app)/dashboard, transacoes, metas, perfil, more/*&lt;br&gt;&lt;br&gt;Axios: base hardcoded http://192.168.15.3:8081/api&lt;br&gt;Services chamam /v1/* para dominios&lt;br&gt;Auth atual: token em memoria; Secure Store instalado mas nao usado" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#4F8FCF;fontSize=12;align=left;verticalAlign=top;spacing=10;" parent="1" vertex="1">
